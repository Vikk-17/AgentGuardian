# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.agentguardian.com

# Agent M2M Credentials
AGENT_AUTH0_CLIENT_ID=your_m2m_client_id
AGENT_AUTH0_CLIENT_SECRET=your_m2m_client_secret

# API Configuration
GUARDIAN_API_URL=http://localhost:3001

# LLM Configuration (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini

# ────────────────────────────────────────────────────────────
# NOTE: No user ID configuration needed!
# 
# Development Mode (Default):
#   - Agent automatically uses the most recently active user
#   - Just log into the dashboard first at http://localhost:5173
#   - No configuration required ✨
#
# Production Mode (Optional):
#   - Configure Auth0 Action to inject user ID into M2M token
#   - See docs/auth0-m2m-action-setup.md for instructions
# ────────────────────────────────────────────────────────────
